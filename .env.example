# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia-esto-password-seguro
POSTGRES_DB=tickets365

# ── Server ────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Dominio y SSL ─────────────────────────────────────────────────
DOMAIN=tudominio.com
CERTBOT_EMAIL=tu@email.com

# ── URLs ──────────────────────────────────────────────────────────
FRONTEND_URL=https://tudominio.com
CORS_ORIGIN=https://tudominio.com
FRONTEND_PROD_URL=https://tudominio.com
BACKEND_PROD_URL=https://tudominio.com

# ── Frontend build args (usados al construir el contenedor frontend) ──
# En producción las URLs son relativas (nginx hace el proxy internamente)
VITE_API_URL=/api
VITE_SOCKET_URL=

# ── Puertos Docker ────────────────────────────────────────────────
FRONTEND_PORT=80

# ── JWT — generar con: openssl rand -base64 48 ────────────────────
JWT_SECRET=
JWT_EXPIRES_IN=7d

# ── Redis (Docker local) ───────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Redis (Upstash Producción) ────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ── Resend / Email ────────────────────────────────────────────────
RESEND_API_KEY=re_

# ── Banco MC4 — Pagos QR ──────────────────────────────────────────
BANCO_QR_API_URL=https://sip.mc4.com.bo:8443
BANCO_QR_API_KEY=
BANCO_QR_SERVICE_KEY=
BANCO_QR_USERNAME=
BANCO_QR_PASSWORD=
BANCO_QR_TIMEOUT=30000

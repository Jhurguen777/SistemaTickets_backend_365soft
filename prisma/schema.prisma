// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USUARIOS Y AUTENTICACIÓN
// ============================================

model Usuario {
  id          String       @id @default(uuid())
  email       String       @unique
  nombre      String
  apellido    String?
  password    String?
  ci          String?
  telefono    String?
  agencia     String?
  googleId    String?      @unique
  rol         Rol          @default(USUARIO)
  activo      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  compras     Compra[]
  asistencias Asistencia[]

  @@map("usuarios")
}

// ============================================
// ROLES DE ADMINISTRACIÓN
// ============================================

model AdminRol {
  id           String    @id @default(uuid())
  nombre       String
  email        String    @unique
  password     String
  tipoRol      TipoRol   @default(GESTOR_EVENTOS)
  estado       EstadoRol @default(ACTIVO)
  ultimoAcceso DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  plantillas   PlantillaCertificado[]

  @@map("roles")
}

// ============================================
// EVENTOS
// ============================================

model Evento {
  id                        String         @id @default(uuid())
  titulo                    String
  descripcion               String?
  fecha                     DateTime
  hora                      String
  ubicacion                 String
  direccion                 String?
  imagenUrl                 String?
  capacidad                 Int
  precio                    Float
  categoria                 String         @default("Fiestas")
  subcategoria              String?
  organizer                 String?
  doorsOpen                 String?
  estado                    EstadoEvento   @default(ACTIVO)
  activo                    Boolean        @default(true)
  seatMapConfig             Json?
  modo                      ModoEvento     @default(ASIENTOS)
  permitirMultiplesAsientos Boolean        @default(false)
  limiteAsientosPorUsuario  Int            @default(1)
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt

  asientos                  Asiento[]
  compras                   Compra[]
  sectores                  SectorEvento[]

  @@map("eventos")
}

// ============================================
// SECTORES DE EVENTOS
// ============================================

model SectorEvento {
  id         String   @id @default(uuid())
  eventoId   String
  nombre     String
  precio     Float
  disponible Int
  total      Int
  createdAt  DateTime @default(now())

  evento     Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)

  @@map("sectores_evento")
}

// ============================================
// ASIENTOS
// ============================================

model Asiento {
  id          String        @id @default(uuid())
  eventoId    String
  fila        String
  numero      Int
  precio      Float?
  estado      EstadoAsiento @default(DISPONIBLE)
  reservadoEn DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  evento      Evento        @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  compra      Compra?

  @@unique([eventoId, fila, numero])
  @@index([eventoId])
  @@map("asientos")
}

// ============================================
// PAGOS QR
// ============================================

model QrPagos {
  id               String    @id @default(uuid())
  alias            String    @unique
  estado           EstadoQr  @default(PENDIENTE)
  monto            Float
  moneda           String    @default("BOB")
  compraId         String?   @unique
  fechaVencimiento DateTime
  imagenQr         String?
  detalleGlosa     String?
  numeroOrden      String?
  nombreCliente    String?
  documentoCliente String?
  cuentaCliente    String?
  fechaproceso     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  compra           Compra?

  @@index([estado])
  @@index([compraId])
  @@map("qr_pagos")
}

// ============================================
// DATOS DE ASISTENTES
// ============================================

model DatosAsistentes {
  id                 String        @id @default(uuid())
  compraId           String       @unique
  nombre             String
  apellido           String
  email              String
  telefono           String?
  documento          String?
  oficina            String?
  asistenciaRegistrada Boolean       @default(false)
  fechaAsistencia    DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  compra             Compra        @relation(fields: [compraId], references: [id], onDelete: Cascade)

  @@index([compraId])
  @@index([email])
  @@index([documento])
  @@map("datos_asistentes")
}

// ============================================
// COMPRAS
// ============================================

model Compra {
  id                 String      @id @default(uuid())
  usuarioId          String
  eventoId           String
  asientoId          String?     @unique
  numeroBoleto       Int?
  monto              Float
  moneda             String      @default("BOB")
  metodoPago         String?
  estadoPago         EstadoPago  @default(PENDIENTE)
  stripePaymentId    String?     @unique
  qrPagoId           String?     @unique
  qrPagoAlias        String?     @unique
  qrCode             String      @unique
  qrCodeUsado        Boolean     @default(false)
  certificadoUrl     String?
  // Datos del asistente (mantenidos por compatibilidad, ahora redundantes)
  nombreAsistente    String?
  apellidoAsistente  String?
  emailAsistente     String?
  telefonoAsistente  String?
  documentoAsistente String?
  oficina            String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  usuario         Usuario           @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  evento          Evento            @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  asiento         Asiento?          @relation(fields: [asientoId], references: [id], onDelete: Cascade)
  qrPago          QrPagos?          @relation(fields: [qrPagoId], references: [id])
  asistencia      Asistencia?
  certificado     Certificado?
  datosAsistente  DatosAsistentes?

  @@index([usuarioId])
  @@index([eventoId])
  @@index([estadoPago])
  @@map("compras")
}

// ============================================
// CERTIFICADOS
// ============================================

model PlantillaCertificado {
  id              String                     @id @default(uuid())
  nombre          String
  tipo            TipoCertificado            @default(PERSONALIZADO)
  descripcion     String?
  contenido       String                     @db.Text
  activo          Boolean                    @default(true)
  creadorId       String?
  creador         AdminRol?                  @relation(fields: [creadorId], references: [id])
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  certificados    Certificado[]
  historialEnvios HistorialEnvioCertificado[]

  @@map("plantillas_certificado")
}

model Certificado {
  id                  String               @id @default(uuid())
  compraId            String?              @unique
  usuarioId           String?
  plantillaId         String
  nombreDestinatario  String?
  emailDestinatario   String?
  codigo              String               @unique
  urlArchivo          String?
  fechaEmision        DateTime             @default(now())
  enviado             Boolean              @default(false)
  fechaEnvio          DateTime?

  compra              Compra?              @relation(fields: [compraId], references: [id], onDelete: Cascade)
  plantilla           PlantillaCertificado @relation(fields: [plantillaId], references: [id])

  @@index([usuarioId])
  @@index([plantillaId])
  @@map("certificados")
}

model HistorialEnvioCertificado {
  id              String               @id @default(uuid())
  plantillaId     String
  eventoId        String
  usuarioId       String?
  cantidadEnviada Int                  @default(0)
  cantidadError   Int                  @default(0)
  error           String?
  fechaEnvio      DateTime             @default(now())

  plantilla       PlantillaCertificado @relation(fields: [plantillaId], references: [id])

  @@map("historial_envios_certificados")
}

// ============================================
// ASISTENCIA
// ============================================

model Asistencia {
  id            String   @id @default(uuid())
  compraId      String   @unique
  usuarioId     String
  ingresoEn     DateTime @default(now())
  validadoPor   String?
  ubicacionGPS  String?
  dispositivoId String?

  compra        Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("asistencias")
}

// ============================================
// REEMBOLSOS
// ============================================

model Reembolso {
  id             String          @id @default(uuid())
  compraId       String          @unique
  monto          Float
  razon          String
  estado         EstadoReembolso @default(SOLICITADO)
  stripeRefundId String?         @unique
  aprobado       Boolean         @default(false)
  solicitadoEn   DateTime        @default(now())
  resolvedoEn    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("reembolsos")
}

// ============================================
// ENUMS
// ============================================

enum Rol {
  USUARIO
  ADMIN
}

enum TipoRol {
  SUPER_ADMIN
  GESTOR_EVENTOS
  GESTOR_REPORTES
  GESTOR_ASISTENCIA
  GESTOR_USUARIOS
}

enum EstadoRol {
  ACTIVO
  INACTIVO
}

enum EstadoEvento {
  ACTIVO
  PAUSADO
  FINALIZADO
  CANCELADO
}

enum ModoEvento {
  ASIENTOS
  CANTIDAD
}

enum EstadoAsiento {
  DISPONIBLE
  RESERVANDO
  VENDIDO
  BLOQUEADO
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  REEMBOLSADO
  FALLIDO
}

enum EstadoQr {
  PENDIENTE
  PAGADO
  CANCELADO
  VENCIDO
}

enum EstadoReembolso {
  SOLICITADO
  EN_REVISION
  APROBADO
  RECHAZADO
  PROCESADO
}

enum TipoCertificado {
  PERSONALIZADO
  ASISTENCIA_ESTANDAR
  FINALIZACION
  EXCELENCIA
}

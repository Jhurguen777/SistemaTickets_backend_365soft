generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id          String       @id @default(uuid())
  email       String       @unique
  nombre      String
  apellido    String?
  password    String?
  ci          String?
  telefono    String?
  agencia     String?
  googleId    String?      @unique
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  asistencias Asistencia[]
  compras     Compra[]

  @@map("usuarios")
}

model Evento {
  id                        String         @id @default(uuid())
  titulo                    String
  descripcion               String?
  fecha                     DateTime
  hora                      String
  ubicacion                 String
  imagenUrl                 String?
  capacidad                 Int
  precio                    Float
  estado                    EstadoEvento   @default(ACTIVO)
  activo                    Boolean        @default(true)
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
  categoria                 String         @default("Fiestas")
  direccion                 String?
  doorsOpen                 String?
  organizer                 String?
  subcategoria              String?
  seatMapConfig             Json?
  permitirMultiplesAsientos Boolean        @default(false)
  limiteAsientosPorUsuario  Int            @default(1)
  asientos                  Asiento[]
  compras                   Compra[]
  sectores                  SectorEvento[]

  @@map("eventos")
}

model SectorEvento {
  id         String   @id @default(uuid())
  eventoId   String
  nombre     String
  precio     Float
  disponible Int
  total      Int
  createdAt  DateTime @default(now())
  evento     Evento   @relation(fields: [eventoId], references: [id], onDelete: Cascade)

  @@map("sectores_evento")
}

model Asiento {
  id          String        @id @default(uuid())
  eventoId    String
  fila        String
  numero      Int
  estado      EstadoAsiento @default(DISPONIBLE)
  reservadoEn DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  evento      Evento        @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  compra      Compra?

  @@unique([eventoId, fila, numero])
  @@index([eventoId])
  @@map("asientos")
}

model Compra {
  id              String      @id @default(uuid())
  usuarioId       String
  eventoId        String
  asientoId       String      @unique
  monto           Float
  moneda          String      @default("USD")
  metodoPago      String?
  estadoPago      EstadoPago  @default(PENDIENTE)
  stripePaymentId String?     @unique
  qrCode          String      @unique
  qrCodeUsado     Boolean     @default(false)
  certificadoUrl  String?
  qrPagoId        String?     @unique
  qrPagoAlias     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  asistencia      Asistencia?
  asiento         Asiento     @relation(fields: [asientoId], references: [id], onDelete: Cascade)
  evento          Evento      @relation(fields: [eventoId], references: [id], onDelete: Cascade)
  usuario         Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  qrPago          QrPago?

  @@index([usuarioId])
  @@index([eventoId])
  @@map("compras")
}

model Asistencia {
  id            String   @id @default(uuid())
  compraId      String   @unique
  usuarioId     String
  ingresoEn     DateTime @default(now())
  validadoPor   String?
  ubicacionGPS  String?
  dispositivoId String?
  compra        Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("asistencias")
}

model Reembolso {
  id             String          @id @default(uuid())
  compraId       String          @unique
  monto          Float
  razon          String
  estado         EstadoReembolso @default(SOLICITADO)
  stripeRefundId String?         @unique
  aprobado       Boolean         @default(false)
  solicitadoEn   DateTime        @default(now())
  resolvedoEn    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("reembolsos")
}

model QrPago {
  id                String      @id @default(uuid())
  compraId          String      @unique
  alias             String      @unique
  estado            EstadoQr    @default(PENDIENTE)
  monto             Float
  moneda            String      @default("BOB")
  fechaVencimiento  DateTime?
  imagenQr          String?     @db.Text
  detalleGlosa      String?
  numeroOrden       String?
  nombreCliente     String?
  documentoCliente  String?
  cuentaCliente     String?
  fechaproceso      DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  compra            Compra      @relation(fields: [compraId], references: [id], onDelete: Cascade)

  @@map("qr_pagos")
}

model Rol {
  id           String         @id @default(uuid())
  nombre       String
  email        String         @unique
  password     String
  tipoRol      TipoRol        @default(GESTOR_EVENTOS)
  estado       EstadoRol      @default(ACTIVO)
  ultimoAcceso DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("roles")
}

enum TipoRol {
  SUPER_ADMIN
  GESTOR_EVENTOS
  GESTOR_REPORTES
  GESTOR_ASISTENCIA
  GESTOR_USUARIOS
}

enum EstadoRol {
  ACTIVO
  INACTIVO
}

enum EstadoEvento {
  ACTIVO
  PAUSADO
  FINALIZADO
  CANCELADO
}

enum EstadoAsiento {
  DISPONIBLE
  RESERVANDO
  VENDIDO
  BLOQUEADO
}

enum EstadoPago {
  PENDIENTE
  PAGADO
  REEMBOLSADO
  FALLIDO
}

enum EstadoReembolso {
  SOLICITADO
  EN_REVISION
  APROBADO
  RECHAZADO
  PROCESADO
}

enum EstadoQr {
  PENDIENTE
  PAGADO
  VENCIDO
  CANCELADO
}

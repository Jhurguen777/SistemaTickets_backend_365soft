# ── Dependencias (se instalan dentro del build) ───────────────────
node_modules/

# ── Build anterior ────────────────────────────────────────────────
dist/

# ── Variables de entorno ──────────────────────────────────────────
.env
.env.*

# ── Docker (no necesario dentro de la imagen) ─────────────────────
docker-compose*.yml
Dockerfile*

# ── Git ────────────────────────────────────────────────────────────
.git/
.gitignore

# ── Logs ───────────────────────────────────────────────────────────
logs/
*.log

# ── Testing ────────────────────────────────────────────────────────
coverage/
__tests__/
*.test.ts
*.spec.ts
jest.config.*

# ── IDE / OS ───────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ── Documentación y scripts ────────────────────────────────────────
*.md
README*
docs/
scripts/

# ── Seed (no se ejecuta en producción) ────────────────────────────
prisma/seed.ts

# ── Temporales ─────────────────────────────────────────────────────
tmp/
temp/
uploads/
